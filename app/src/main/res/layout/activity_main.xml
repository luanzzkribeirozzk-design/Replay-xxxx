<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#080800">

    <!-- BOTÃO FIXO SENSI CONFIG NO RODAPÉ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:background="#E6050500"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="10dp"
        android:paddingBottom="16dp"
        android:elevation="8dp">

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#BF00FF"
            android:layout_marginBottom="10dp" />

        <Button
            android:id="@+id/btnSensiConfig"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="⚙  SENSI CONFIG"
            android:textColor="#000000"
            android:textSize="14sp"
            android:textStyle="bold"
            android:background="@drawable/btn_primary"
            android:stateListAnimator="@null" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Configurador de Sensibilidade · DEV WILL TECHX"
            android:textColor="#7B00AA"
            android:textSize="10sp"
            android:layout_gravity="center"
            android:layout_marginTop="4dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#1AEAFF00"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnOtimizador"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="⚡  OTIMIZADOR FF"
            android:textColor="#EAFF00"
            android:textSize="14sp"
            android:textStyle="bold"
            android:background="@drawable/btn_clear"
            android:stateListAnimator="@null" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="FPS Máximo · 54 Comandos · Free Fire &amp; FF MAX"
            android:textColor="#7B00AA"
            android:textSize="10sp"
            android:layout_gravity="center"
            android:layout_marginTop="4dp" />

    </LinearLayout>

    <com.replayx.app.ui.ParticleView
        android:id="@+id/particleView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- BACKGROUND IMAGE -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/bg_volpp"
        android:scaleType="centerCrop"
        android:alpha="0.6" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- HEADER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#00000088"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="44dp"
            android:paddingBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BY: DEV WILL"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:letterSpacing="0.4"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Dev Will"
                android:textColor="#FFFFFF"
                android:textSize="36sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="2dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="BYPASS  ·  DEV WILL"
                    android:textColor="#7B00AA"
                    android:textSize="10sp" />

                <TextView
                    android:id="@+id/tvShizukuStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="● VERIFICANDO"
                    android:textColor="#FFD700"
                    android:textSize="10sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <!-- TIMER DA KEY -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="8dp">

                <TextView
                    android:id="@+id/tvKeyInfo"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text=""
                    android:textColor="#7B00AA"
                    android:textSize="9sp"
                    android:fontFamily="monospace"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/tvTimer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="00d 00h 00m 00s"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace" />

            </LinearLayout>

        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#BF00FF" />

        <!-- HIDE STREAM -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#00000099"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="HIDE STREAM"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace" />

                <TextView
                    android:id="@+id/tvHideStreamStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="HIDE STREAM: OFF"
                    android:textColor="#444444"
                    android:textSize="10sp"
                    android:fontFamily="monospace"
                    android:layout_marginTop="2dp" />

            </LinearLayout>

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switchHideStream"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="false" />

        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#181200" />

        <!-- BOTOES -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:background="#00000066">

            <Button
                android:id="@+id/btnBypassMaxToNormal"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:text="BYPASS  FFM = FFN"
                android:textColor="#000000"
                android:textSize="14sp"
                android:textStyle="bold"
                android:background="@drawable/btn_primary"
                android:stateListAnimator="@null"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Free Fire MAX  →  Free Fire Normal"
                android:textColor="#006600"
                android:textSize="10sp"
                android:layout_gravity="center"
                android:layout_marginBottom="10dp" />

            <Button
                android:id="@+id/btnBypassNormalToMax"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:text="BYPASS  FFN = FFM"
                android:textColor="#000000"
                android:textSize="14sp"
                android:textStyle="bold"
                android:background="@drawable/btn_secondary"
                android:stateListAnimator="@null"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Free Fire Normal  →  Free Fire MAX"
                android:textColor="#006600"
                android:textSize="10sp"
                android:layout_gravity="center"
                android:layout_marginBottom="10dp" />

            <Button
                android:id="@+id/btnClearLog"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:text="Limpar logs"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold"
                android:background="@drawable/btn_clear"
                android:stateListAnimator="@null" />

        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#181200" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#00000088"
            android:orientation="horizontal"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="root@devwill:~/ bypass_log"
                android:textColor="#00AA22"
                android:textSize="10sp"
                android:fontFamily="monospace" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="v2.0"
                android:textColor="#003311"
                android:textSize="10sp" />

        </LinearLayout>

        <ScrollView
            android:id="@+id/scrollLog"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="#00000099"
            android:padding="12dp"
            android:scrollbars="none">

            <TextView
                android:id="@+id/tvLog"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:text=""
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:lineSpacingExtra="2dp" />

        </ScrollView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#00000088"
            android:paddingVertical="8dp"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Dev Will  ·  Dev Will"
                android:textColor="#7B00AA"
                android:textSize="9sp" />

        </LinearLayout>

    </LinearLayout>
</FrameLayout>
