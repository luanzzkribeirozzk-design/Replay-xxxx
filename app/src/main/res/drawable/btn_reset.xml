<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#A64FDB"
                android:endColor="#7A22B0"
                android:angle="90" />
            <corners android:radius="12dp" />
            <stroke android:width="1.5dp" android:color="#E0B3FF" />
        </shape>
    </item>
    <item android:state_enabled="false">
        <shape android:shape="rectangle">
            <solid android:color="#22110022" />
            <corners android:radius="12dp" />
            <stroke android:width="1dp" android:color="#442255" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#CC66FF"
                android:endColor="#9B2FE0"
                android:angle="90" />
            <corners android:radius="12dp" />
        </shape>
    </item>
</selector>
