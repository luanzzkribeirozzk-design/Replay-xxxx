<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#C6D900"
                android:endColor="#9FB000"
                android:angle="90" />
            <corners android:radius="12dp" />
            <stroke android:width="1.5dp" android:color="#FFF177" />
        </shape>
    </item>
    <item android:state_enabled="false">
        <shape android:shape="rectangle">
            <solid android:color="#22221100" />
            <corners android:radius="12dp" />
            <stroke android:width="1dp" android:color="#443300" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#FFF177"
                android:endColor="#EAFF00"
                android:angle="90" />
            <corners android:radius="12dp" />
        </shape>
    </item>
</selector>
